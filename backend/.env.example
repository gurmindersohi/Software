# ---------------------------------------------------------------------------
# Sohi backend environment. Copy to `.env` and fill in real values locally.
# NEVER commit a real `.env`. All secrets below were ROTATED during migration
# (the old .NET appsettings.json leaked live keys into git history — task 0.6).
# ---------------------------------------------------------------------------

# App
APP_NAME="Sohi API"
ENVIRONMENT=local            # local | staging | production
DEBUG=true
SECRET_KEY=change-me-with-a-long-random-string

# Database (Postgres). Async driver via psycopg3.
DATABASE_URL=postgresql+psycopg://sohi:sohi@localhost:5432/sohi

# Redis (arq background worker / rate limiting)
REDIS_URL=redis://localhost:6379/0

# Object storage (S3-compatible; MinIO locally)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=sohi-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Auth (Phase 2)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — the Next.js frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# --- Integrations (Phase 4) — ROTATE these, do not reuse old leaked values ---
# Facebook / Meta Graph API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v19.0
FACEBOOK_REDIRECT_URL=http://localhost:8000/api/v1/integrations/facebook/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email provider (Phase 2.6)
EMAIL_PROVIDER=console        # console | resend | sendgrid
EMAIL_FROM=no-reply@sohi.app
RESEND_API_KEY=
