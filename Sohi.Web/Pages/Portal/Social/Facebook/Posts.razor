@inherits PostsBase
@layout FacebookLayout

@page "/Portal/Social/Facebook/Posts"

<div class="container-fluid m-0" style="max-width: 1000px; min-height: calc(100vh - 100px);">

    @if (Posts == null)
    {
        <div class="spinner"></div>

    }
    else
    {
        @foreach (var post in Posts)
        {
            <div class="card mt-3">
                <div class="card-header">

                    <div class="row">
                        <div class="col" style="flex:0;">
                            <img src="/images/img_avatar.png" height="50" width="50" class="rounded-circle" />
                        </div>
                        <div class="col">
                            <div class="row">
                                <div class="" style="color:black; font-weight:600;">
                                    Gurminder Singh
                                </div>
                                <div class="" style="font-size: 13px;">
                                    May 7, 2020 at 6:04 PM

                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-9">
                            <p class="card-text"></p>
                        </div>
                        <div class="col-md-3">
                            <img src="/images/img_avatar.png" height="200" width="200" class="img-fluid rounded mx-auto d-block" asp-append-version="true" />
                        </div>
                    </div>
                </div>
                <div class="card-footer text-muted">
                    <div class="row" style="text-align: center; ">
                        <div class="col">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="">
                                        <span class="" dir="auto">0</span>
                                    </div>
                                    <div class="">
                                        <span class="" dir="auto">Likes</span>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="col">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="">
                                        <span class="" dir="auto">0</span>
                                    </div>
                                    <div class="">
                                        <span class="" dir="auto">People Reached</span>
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="col">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="">
                                        <span class="" dir="auto">0</span>
                                    </div>
                                    <div class="">
                                        <span class="" dir="auto">Engagements</span>
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="col">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="">
                                        <span class="" dir="auto">0</span>
                                    </div>
                                    <div class="">
                                        <span class="" dir="auto">Post Clicks</span>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>

                </div>
            </div>
        }
    }
</div>
