@using Sohi.Models;

@if (FacebookProfile != null)
{
    <div class="card mt-3">

        <div class="card-body">
            <blockquote class="blockquote" style="margin-bottom:0rem;">
                <div class="row">
                    <div class="col" style="flex:0;">
                        <img src="@FacebookProfile.Image" height="50" width="50" class="rounded-circle" />
                    </div>
                    <div type="button" data-bs-toggle="modal" data-bs-target="#createPostPopup" class="col p-2" style="background-color:#f0f2f5;  border-radius: 25px; font-size: 0.9rem; line-height:2; padding-left: 20px!important; color:#838589">
                        What's on your mind, @FacebookProfile.Name?
                    </div>
                </div>
            </blockquote>
        </div>
    </div>
}

    @code {

        [CascadingParameter(Name = "FacebookProfile")]
        public Profile FacebookProfile { get; set; }

    }
