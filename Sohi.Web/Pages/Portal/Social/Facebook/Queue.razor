@layout FacebookLayout

@page "/Portal/Social/Facebook/{PageId}"
@page "/Portal/Social/Facebook/{PageId}/Queue"

@inherits QueueBase


<div class="container-fluid m-0 mb-1" style="max-width: 1000px; min-height: calc(100vh - 100px);">
    @if (Posts == null)
    {

        if (flag)
        {

            @*<CreatePost Profile="Profile"></CreatePost>*@
            <div class="card mt-3">

                <div class="card-body">
                    <blockquote class="blockquote" style="margin-bottom:0rem;">
                        <div class="row">
                            <div class="col" style="flex:0;">
                                <img src="@Profile.Image" height="50" width="50" class="rounded-circle" />
                            </div>
                            <div type="button" data-bs-toggle="modal" data-bs-target="#createPostPopup" class="col p-2" style="background-color:#f0f2f5;  border-radius: 25px; font-size: 0.9rem; line-height:2; padding-left: 20px!important; color:#838589">
                                What's on your mind, @Profile.Name?
                            </div>
                        </div>
                    </blockquote>
                </div>
            </div>


            <div class="conatiner pt-5">
                <div class="row text-center">
                    <div class="col-md-12 p-3 header">
                        <h1 style="color: #a4a4a4">You haven't scheduled any post yet!</h1>
                    </div>
                </div>


            </div>
        }
        else
        {
            @*<Loader></Loader>*@
            <SmallLoader StyleClass="pt-5"></SmallLoader>

        }

    }

    else
    {
        @*<CreatePost Profile="Profile"></CreatePost>*@
        <div class="card mt-3">

            <div class="card-body">
                <blockquote class="blockquote" style="margin-bottom:0rem;">
                    <div class="row">
                        <div class="col" style="flex:0;">
                            <img src="@Profile.Image" height="50" width="50" class="rounded-circle" />
                        </div>
                        <div type="button" data-bs-toggle="modal" data-bs-target="#createPostPopup" class="col p-2" style="background-color:#f0f2f5;  border-radius: 25px; font-size: 0.9rem; line-height:2; padding-left: 20px!important; color:#838589">
                            What's on your mind, @Profile.Name?
                        </div>
                    </div>
                </blockquote>
            </div>
        </div>


        @foreach (var post in Posts)
        {
            <div class="card mt-3">
                <div class="card-header">
                    Post on @post.CreatedTime
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-9">
                            <p class="card-text">@post.Description</p>
                        </div>
                        <div class="col-md-3">
                            <img src="@post.Picture" height="200" width="200" class="img-fluid rounded mx-auto d-block" />
                        </div>
                    </div>
                </div>
                <div class="card-footer text-muted">
                    <div class="row">
                        <div class="col-md-9 ">
                            <p class="align-items-middle" style="font-size: 14px;">This Post will be sent on <b>@post.CreatedTime</b>.</p>
                        </div>
                        <div class="col-md-3 end-0 text-center">

                            <a href="#" class="btn btn-danger btn-sm" tabindex="-1" role="button" aria-disabled="true">Delete</a>
                            <a href="#" class="btn btn-warning btn-sm" tabindex="-1" role="button" aria-disabled="true">Edit</a>
                            <a href="#" class="btn btn-primary btn-sm" tabindex="-1" role="button" aria-disabled="true">Share Now</a>

                            @*<button type="button" class="btn btn-danger">Delete</button>
                                <button type="button" class="btn btn-warning">Edit</button>
                                <button type="button" class="btn btn-primary">Share Now</button>*@
                        </div>
                    </div>
                    @*<table style="">
                            <tbody>
                                <tr>
                                    <td class="align-middle col-md-8s">
                                        This Post will be sent on April 9th at 9:30 AM (BST).
                                    </td>
                                    <td class="align-middle col-md-4 me-auto">
                                        <button type="button" class="btn btn-danger">Delete</button>
                                        <button type="button" class="btn btn-warning">Edit</button>
                                        <button type="button" class="btn btn-primary">Share Now</button>
                                    </td>

                                </tr>
                            </tbody>
                        </table>*@
                </div>
            </div>
        }
    }
</div>


<!-- Modal -->
<div class="modal fade" id="createPostPopup" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="PopupLabel" aria-hidden="true">
    <div class="modal-dialog  modal-dialog-centered modal-dialog-scrollable">

        <form class="w-100" method="post">
            <div class="modal-content">
                <div class="modal-header text-center">
                    <h5 class="modal-title " id="PopupLabel">Create Post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">

                    @*<div class="row pb-3">
                            <div class="col-md-12">

                                <img src="/images/img_avatar.png" height="50" width="50" class="rounded-circle" />
                                <img src="/images/img_avatar.png" height="50" width="50" class="rounded-circle" />

                            </div>
                        </div>*@

                    <div class="">

                        <div class="row pt-2 pb-2">
                            <div class="col-md-12">
                                <textarea asp-for="Description" class="form-control border-0" placeholder="Write something to share..." rows="5" style="box-shadow: none;"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row pt-2 pb-2">
                            <div class="col-md-12">

                                <div class="row pt-2 pb-2">
                                    <div class="col-md-12">
                                        <div class="pb-2" style="color:rgb(99, 99, 99); font-weight:600;">
                                            Media
                                        </div>
                                        @*<div class="form-control">

                                                <InputFile OnChange="@LoadFiles" id="customFile" type="file" name="file" multiple class="form-control mt-4 mb-4" />

                                                <span asp-validation-for="File" class="text-danger"></span>
                                            </div>*@
                                        <span asp-validation-for="Description" class="text-danger"></span>
                                    </div>
                                </div>

                                @if (SelectedImage != null)
                                {
                                    <div class="row pt-2 pb-2">
                                        <div class="col f-0">
                                            <div style="height:96px; width: 96px; position:relative;background-color: rgb(242,242,242); border-radius: 7px;">
                                                <img src="@SelectedImage.Url" class="card-img-top" style="border-radius: 7px; position: absolute; top: 0; bottom: 0; left: 0; right: 0; margin: auto;" alt="...">
                                            </div>
                                        </div>
                                        <div class="col">
                                            <div class="">
                                                <a class="btn btn-sm btn-primary m-1" type="button" @onclick="ImageSelected">Change</a>
                                            </div>
                                            <div class="">
                                                <a class="btn btn-sm btn-danger m-1" type="button" @onclick="RemoveSelectedImage">Remove</a>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="row pb-2">
                                        <div class="col">
                                            <div class="dropdown">
                                                <button class="btn dropdown-toggle" type="button" id="Media" data-bs-toggle="dropdown" aria-expanded="false" style="background-color: rgb(242, 242, 242); color: black; border: 1px solid rgb(242, 242, 242); box-shadow:none">
                                                    Add Media
                                                </button>
                                                <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton1">
                                                    <li><a class="dropdown-item" type="button" @onclick="ImageSelected">Add Image</a></li>
                                                    <li><a class="dropdown-item" href="#">Add Video</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @*<input asp-for="File" type="file" class="form-control" id="customFile" />
                                    <span asp-validation-for="File" class="text-danger"></span>*@

                            </div>
                        </div>
                    </div>

                    @*<div class="row pt-3">
                            <div class="col-md-11">

                                <div class="form-check form-switch p-0">
                                    <label class="form-check-label" for="ScheduleSwitch"><i class="fa fa-calendar" aria-hidden="true"></i>Schedule Post</label>
                                </div>

                            </div>
                            <div class="col-md-1">

                                <div class="form-check form-switch p-0">
                                    <input class="form-check-input" type="checkbox" id="ScheduleSwitch">
                                </div>

                            </div>
                        </div>*@
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="modal-footer">
                    @*<button type="button" class="btn btn-primary">Schedule</button>*@
                    <button type="button" class="btn btn-primary" asp-action="Share" asp-controller="Facebook">Share</button>
                </div>
            </div>
        </form>
    </div>
</div>


<SocialImages SelectionChanged="ImageSelected_Click" @ref="OpenSocialImagesModalConfirmation" user="user"></SocialImages>
