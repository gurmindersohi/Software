@layout SocialLayout
@*@page "/Portal/Social"*@
@page "/Portal/Social/Create"

@inherits CreateBase

@if (TotalAccounts == null)
{
    if (!flag)
    {
        <Connect></Connect>
    }
    else
    {
        <div class="spinner"></div>

    }

}

else
{
    <div class="top-create-row">

    </div>

    <div class="container-fluid m-0 pt-2 pb-5" style="max-width: 800px;">
        <form method="post">
            <EditForm Model="@Post" OnValidSubmit="CreatePost">
                <div class="content">
                    <div class="header text-center">
                        <h5 class="title " id="PopupLabel">Create Post</h5>
                    </div>
                    <div class="body">

                        <div class="">

                            <div class="row pt-2 pb-2">
                                <div class="col-md-12">
                                    <div class="pb-2" style="color:rgb(99, 99, 99); font-weight:600;">
                                        Add text to your post
                                    </div>
                                    <textarea asp-for="Description" class="form-control" placeholder="Write something to share..." rows="5" style="box-shadow: none;"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row pt-2 pb-2">
                                <div class="col-md-12">
                                    <div class="pb-2" style="color:rgb(99, 99, 99); font-weight:600;">
                                        Media
                                    </div>
                                    <div class="form-control">
                                        <input asp-for="File" type="file" class="form-control mt-4 mb-4" id="customFile" />
                                        <span asp-validation-for="File" class="text-danger"></span>
                                    </div>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row pt-2 pb-2">
                                <div class="col-md-12">
                                    <div class="pb-2" style="color:rgb(99, 99, 99); font-weight:600;">
                                        Post on
                                    </div>
                                    <div class="form-control">
                                        @if (TotalAccounts.Count == 0)
                                        {
                                            @if (!flag)
                                            {
                                                <SmallLoader StyleClass="p-1"></SmallLoader>
                                            }
                                            else
                                            {
                                                <div class="pb-2 text-center" style="color:rgb(99, 99, 99); font-weight:600;">
                                                    No account is connected!
                                                </div>
                                            }
                                        }
                                        else
                                        {

                                            @foreach (var profile in TotalAccounts)
                                            {
                                                @*<img src="@profile.Image" height="50" width="50" class="rounded-circle ms-1" />*@

                                                <div class="row p-2 px-3 pt-3 pb-3 no-border" style="background-color: white; border-bottom: 1px solid rgba(0,0,0,.125);">
                                                    <div class="col" style="flex:0; padding-left:0;">
                                                        <img src="@profile.Image" height="35" width="35" class="rounded-circle" />
                                                    </div>
                                                    <div class="col ps-0">
                                                        <div class="row">
                                                            <div class="" style="color:black; font-weight:600; font-size: 15px; line-height: 1.2;">
                                                                @profile.Name
                                                            </div>
                                                            <div class="" style="font-size: 12px; font-weight: 500; color:rgba(40,43,49,.7);">
                                                                @profile.Type
                                                            </div>
                                                        </div>

                                                    </div>

                                                    <div class="col me-0 pe-0 text-end" style="flex:0.5; padding-left:1%; padding-top: 5px;">
                                                        <div class="row">
                                                            <div class="" style="color:black; font-weight:600; font-size: 15px; line-height: 1.2;">
                                                                <label class="switch">
                                                                    <input type="checkbox" checked @onchange="() => CheckboxClicked(profile)">
                                                                    <span class="slider round"></span>
                                                                </label>

                                                            </div>

                                                        </div>
                                                    </div>

                                                </div>

                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                            @if (SchedulePost)
                            {
                                <div id="Schedule">
                                    <div class="modal fade show d-block" id="exampleModal" tabindex="-1" role="dialog" style="background-color:rgba(40,43,49,.7);">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="exampleModalLabel">Schedule Post</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                                                             @onclick="() => SchedulePost_Click(false)">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <label for="CampaignName" class="col-form-label CustomFont" style="font-size:11px;">
                                                                Schedule Date
                                                            </label>
                                                        </div>
                                                    </div>

                                                    <div class="row">
                                                        <div class="col f-0">
                                                            <InputDate id="StartDate" class="form-control w-auto" minDate="@DateTime.Now"
                                                                       @bind-Value="ScheduleDate" />
                                                            <ValidationMessage For="@(() => ScheduleDate)" />

                                                        </div>
                                                        <div class="col">
                                                            <input type="time" class="form-control w-auto" @bind-value="ScheduleTime" required>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal"
                                                             @onclick="() => SchedulePost_Click(false)">
                                                        Cancel
                                                    </button>
                                                    <button type="button" class="btn btn-primary">
                                                        Schedule
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                        </div>



                        @*<div class="row pt-3">
                                <div class="col-md-11">

                                    <div class="form-check form-switch p-0">
                                        <label class="form-check-label" for="ScheduleSwitch"><i class="fa fa-calendar" aria-hidden="true"></i>Schedule Post</label>
                                    </div>

                                </div>
                                <div class="col-md-1">

                                    <div class="form-check form-switch p-0">
                                        <input class="form-check-input" type="checkbox" id="ScheduleSwitch">
                                    </div>

                                </div>
                            </div>*@
                    </div>

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="footer">
                        <button type="button" class="btn btn-primary" @onclick="() => SchedulePost_Click(true)">Schedule</button>

                        <button type="submit" class="btn btn-primary ms-2">Share</button>
                    </div>
                </div>

            </EditForm>
        </form>

    </div>

}
<style>


    .top-create-row {
        /*    background-color: #f7f7f7;*/
        border-bottom: 1px solid #d6d5d5;
        /*    justify-content: flex-end; */
        display: flex;
        align-items: center;
        background-color: #fff;
        /*    z-index: 1030;*/
        height: 3.5rem;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .content {
        padding-top: 0rem;
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        pointer-events: auto;
        background-color: #fff;
        background-clip: padding-box;
        border: 1px solid rgba(0,0,0,.2);
        border-radius: .3rem;
        outline: 0;
    }

    .header {
        /* display: flex; */
        flex-shrink: 0;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1rem;
        border-bottom: 1px solid #dee2e6;
        border-top-left-radius: calc(.3rem - 1px);
        border-top-right-radius: calc(.3rem - 1px);
    }

    .title {
        margin-bottom: 0;
        line-height: 1.5;
    }

    .body {
        position: relative;
        flex: 1 1 auto;
        padding: 1rem;
    }

    .footer {
        display: flex;
        flex-wrap: wrap;
        flex-shrink: 0;
        align-items: center;
        justify-content: flex-end;
        padding: .75rem;
        border-top: 1px solid #dee2e6;
        border-bottom-right-radius: calc(.3rem - 1px);
        border-bottom-left-radius: calc(.3rem - 1px);
    }
</style>

<style>
    .switch {
        position: relative;
        display: inline-block;
        width: 43px;
        height: 25px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        -webkit-transition: .4s;
        transition: .4s;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            -webkit-transition: .4s;
            transition: .4s;
        }

    input:checked + .slider {
        background-color: #2196F3;
    }

    input:focus + .slider {
        box-shadow: 0 0 1px #2196F3;
    }

    input:checked + .slider:before {
        -webkit-transform: translateX(18px);
        -ms-transform: translateX(18px);
        transform: translateX(18px);
    }

    /* Rounded sliders */
    .slider.round {
        border-radius: 25px;
    }

        .slider.round:before {
            border-radius: 50%;
        }


    .no-border:first-of-type {
        border-top: none !important;
    }

    .no-border:last-of-type {
        border-bottom: none !important;
    }
</style>
