@layout SocialLayout
@page "/Portal/Social"
@page "/Portal/Social/Create"

@code {

}

<div class="top-create-row">

</div>

<form method="post">

    <div class="container-fluid mt-5" style="background-color:#fff !important; height: calc(100vh - 0px);">



        <div class="row" style="width:100%;">

            <div class="col-md-1"></div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        Create a post
                    </div>
                    <div class="card-body">

                        <div class="col-md-12">


                            <div class="form-group">
                                <label for="uploadfile">Media</label>
                                <input type="file" class="form-control" id="uploadfile">
                            </div>

                            <br />


                            <div class="form-group">
                                <label for="txtdescription">Description</label>
                                <textarea rows="10" class="form-control" id="txtdescription"></textarea>
                            </div>
                            <br />


                            <br />
                            <button type="submit" class="btn btn-primary me-auto">Post</button>

                        </div>
                    </div>





                </div>

            </div>




        </div>

    </div>

</form>

<style>


    .top-create-row {
        /*    background-color: #f7f7f7;*/
        border-bottom: 1px solid #d6d5d5;
        /*    justify-content: flex-end; */
        display: flex;
        align-items: center;
        background-color: #fff;
        /*    z-index: 1030;*/
        height: 3.5rem;
        position: sticky;
        top: 0;
        z-index: 1;
    }

</style>
