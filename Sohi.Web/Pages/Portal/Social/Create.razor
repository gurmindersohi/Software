@layout SocialLayout
@page "/Portal/Social"
@page "/Portal/Social/Create"

@inherits CreateBase

@if (Profiles == null)
{
    <div class="spinner"></div>

}

else
{
<div class="top-create-row">

</div>

<div class="container-fluid m-0 pt-2" style="max-width: 1000px;">
    <form method="post">
        <EditForm Model="@Post" OnValidSubmit="CreatePost">
            <div class="content">
                <div class="header text-center">
                    <h5 class="title " id="PopupLabel">Create Post</h5>
                </div>
                <div class="body">

                    <div class="row pb-3">
                        <div class="col-md-12">
                            @foreach (var profile in Profiles)
                            {
                                <img src="@profile.Image" height="50" width="50" class="rounded-circle ms-1" />

                            }

                        </div>
                    </div>

                    <div class="">

                        <div class="row pt-2 pb-2">
                            <div class="col-md-12">
                                <textarea asp-for="Description" class="form-control border-0" placeholder="Write something to share..." rows="5" style="box-shadow: none;"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row pt-2 pb-2">
                            <div class="col-md-12">
                                <input asp-for="File" type="file" class="form-control" id="customFile" />
                                <span asp-validation-for="File" class="text-danger"></span>

                            </div>
                        </div>
                    </div>

                    @*<div class="row pt-3">
                            <div class="col-md-11">

                                <div class="form-check form-switch p-0">
                                    <label class="form-check-label" for="ScheduleSwitch"><i class="fa fa-calendar" aria-hidden="true"></i>Schedule Post</label>
                                </div>

                            </div>
                            <div class="col-md-1">

                                <div class="form-check form-switch p-0">
                                    <input class="form-check-input" type="checkbox" id="ScheduleSwitch">
                                </div>

                            </div>
                        </div>*@
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="footer">
                    @*<button type="button" class="btn btn-primary">Schedule</button>*@

                    <button type="submit" class="btn btn-primary">Share</button>
                </div>
            </div>

        </EditForm>
    </form>

</div>

}
<style>


    .top-create-row {
        /*    background-color: #f7f7f7;*/
        border-bottom: 1px solid #d6d5d5;
        /*    justify-content: flex-end; */
        display: flex;
        align-items: center;
        background-color: #fff;
        /*    z-index: 1030;*/
        height: 3.5rem;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .content {
        padding-top: 0rem;
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        pointer-events: auto;
        background-color: #fff;
        background-clip: padding-box;
        border: 1px solid rgba(0,0,0,.2);
        border-radius: .3rem;
        outline: 0;
    }

    .header {
        /* display: flex; */
        flex-shrink: 0;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1rem;
        border-bottom: 1px solid #dee2e6;
        border-top-left-radius: calc(.3rem - 1px);
        border-top-right-radius: calc(.3rem - 1px);
    }

    .title {
        margin-bottom: 0;
        line-height: 1.5;
    }

    .body {
        position: relative;
        flex: 1 1 auto;
        padding: 1rem;
    }

    .footer {
        display: flex;
        flex-wrap: wrap;
        flex-shrink: 0;
        align-items: center;
        justify-content: flex-end;
        padding: .75rem;
        border-top: 1px solid #dee2e6;
        border-bottom-right-radius: calc(.3rem - 1px);
        border-bottom-left-radius: calc(.3rem - 1px);
    }
</style>
