@layout SocialLayout
@page "/Portal/Social"
@page "/Portal/Social/Create"

@code {

}

<form method="post">

    <div class="container-fluid mt-5" style="background-color:#f8f9fa !important; height: calc(100vh - 0px);">



        <div class="row" style="width:100%;">

            <div class="col-md-1"></div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        Create a post
                    </div>
                    <div class="card-body">

                        <div class="col-md-12">


                            <div class="form-group">
                                <label for="uploadfile">Media</label>
                                <input type="file" class="form-control" id="uploadfile">
                            </div>

                            <br />


                            <div class="form-group">
                                <label for="txtdescription">Description</label>
                                <textarea rows="10" class="form-control" id="txtdescription"></textarea>
                            </div>
                            <br />
                               

                                <br />
                            <button type="submit" class="btn btn-primary me-auto">Post</button>

                        </div>
                    </div>





                </div>

            </div>




        </div>

    </div>

</form>
