@page "/Portal/Leads/EditLead/{LeadId}"
@page "/Portal/Leads/EditLead"

@inherits EditLeadBase

<EditForm Model="@EditLeadModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <h3>@PageHeader</h3>
    <hr />
    <ValidationSummary />

    <div class="form-group row">
        <label for="firstName" class="col-sm-2 col-form-label">
            First Name
        </label>
        <div class="col-sm-10">
            <InputText id="firstName" class="form-control" placeholder="First Name"
                       @bind-Value="EditLeadModel.FirstName" />
            <ValidationMessage For="@(() => EditLeadModel.FirstName)" />
        </div>
    </div>
    <div class="form-group row">
        <label for="lastName" class="col-sm-2 col-form-label">
            Last Name
        </label>
        <div class="col-sm-10">
            <InputText id="lastName" class="form-control" placeholder="Last Name"
                       @bind-Value="EditLeadModel.LastName" />
            <ValidationMessage For="@(() => EditLeadModel.LastName)" />
        </div>
    </div>
    <div class="form-group row">
        <label for="email" class="col-sm-2 col-form-label">
            Email
        </label>
        <div class="col-sm-10">
            <InputText id="email" class="form-control" placeholder="Email"
                       @bind-Value="EditLeadModel.Email" />
            <ValidationMessage For="@(() => EditLeadModel.Email)" />
        </div>
    </div>
    <div class="form-group row">
        <label for="email" class="col-sm-2 col-form-label">
            Confirm Email
        </label>
        <div class="col-sm-10">
            <InputText id="email" class="form-control" placeholder="Email"
                       @bind-Value="EditLeadModel.ConfirmEmail" />
        </div>
    </div>
    <div class="form-group row">
        <label for="email" class="col-sm-2 col-form-label">
            Date Of Birth
        </label>
        <div class="col-sm-10">
            <InputDate @bind-Value="EditLeadModel.DateOfBirth" />
        </div>
    </div>
    <button type="submit">Save</button>
    <button class="btn btn-danger m-1" type="button" @onclick="Delete_Click">Delete</button>
</EditForm>
