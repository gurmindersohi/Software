

@inherits CampaignsListBase
@layout FacebookAdsLayout

@page "/Portal/Ads/Facebook/{AccountId}/CampaignsList"
@page "/Portal/Ads/Facebook/{AccountId}"

@if (Campaigns == null)
{
    if (flag)
    {
        <Empty Message="No Campaigns to show."></Empty>
    }
    else
    {
        <SmallLoader StyleClass="pt-5"></SmallLoader>
    }
}
else
{

    <table id="example" class="table table-striped" style="width:100%">
        <thead>
            <tr>
                <th></th>
                <th>Campaign Name</th>
                <th>Status</th>
                <th>Objective</th>
                <th>Start Date</th>
                @*<th>Email</th>
        <th>Phone</th>
        <th>Gender</th>
        <th>Lead Source</th>
        <th>Created On</th>
        <th>Actions</th>*@
            </tr>
        </thead>
        <tbody>
            @foreach (var campaign in Campaigns)
            {
            <tr>
                <td>
                    <div class="" style="color:black; font-weight:600; font-size: 15px; line-height: 1.2;">
                        <label class="switch">
                            <input type="checkbox" checked="@campaign.Status">
                            <span class="slider round"></span>
                        </label>

                    </div>
                </td>
                <td>@campaign.Name</td>
                <td>@campaign.StatusString</td>
                <td>@campaign.Objective.Replace("_", " ")</td>
                <td>@campaign.StartTime.ToLongDateString()</td>

            </tr>
            }
        </tbody>
    </table>
}


<style>
    .switch {
        position: relative;
        display: inline-block;
        width: 43px;
        height: 25px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        -webkit-transition: .4s;
        transition: .4s;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            -webkit-transition: .4s;
            transition: .4s;
        }

    input:checked + .slider {
        background-color: #2196F3;
    }

    input:focus + .slider {
        box-shadow: 0 0 1px #2196F3;
    }

    input:checked + .slider:before {
        -webkit-transform: translateX(18px);
        -ms-transform: translateX(18px);
        transform: translateX(18px);
    }

    /* Rounded sliders */
    .slider.round {
        border-radius: 25px;
    }

        .slider.round:before {
            border-radius: 50%;
        }


    .no-border:first-of-type {
        border-top: none !important;
    }

    .no-border:last-of-type {
        border-bottom: none !important;
    }
</style>