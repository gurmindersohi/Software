


@page "/AdImages"

@inherits AdImagesBase

@if (ShowAdImagesModal)
{
    <div class="modal d-block" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" style="background-color:rgba(40,43,49,.7);">
        <div class="modal-dialog" style="top:5%; max-width:850px !important;">

            @*<EditForm Model="@Profiles">*@
            <div class="modal-content">
                <div class="modal-header pb-2" style="display:block !important; padding-top:0.7rem;">
                    <div class="row">
                        <div class="col">
                            <h5 class="modal-title" id="staticBackdropLabel" style=" font-size: 16px; font-weight: bolder; color: #000000BF; font-family: Roboto, Arial, sans-serif; ">
                                Select Image
                            </h5>
                        </div>
                    </div>

                    <div class="row pt-2">
                        <div class="col">
                            <div id="UploadAdImageDiv" class="file btn btn-sm btn-light px-3 py-2" style="background-color: rgb(242, 242, 242); border-radius: 5px;">
                                <span class="oi oi-plus" style="font-size: 0.7rem;"></span>&nbsp;Upload

                                <InputFile OnChange="@LoadFiles" id="UploadAdImageInput" type="file" name="file" multiple />

                                @if (isLoading)
                                {
                                    <SmallLoader></SmallLoader>
                                }


                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-body pe-0">
                    <div class="row ps-0 pt-2 pe-0">

                        @if (AdImages == null)
                        {
                            <SmallLoader></SmallLoader>
                        }
                        else
                        {
                            foreach (var image in AdImages)
                            {
                                <a @onclick="() => OnSelectionChange(image)" class="col Image" style="flex:0.1; text-decoration:none;">

                                    <div class="card" style="width: 96px; border:none;">
                                        <div style="height:96px; width: 96px; position:relative;background-color: rgb(242,242,242); border-radius: 7px;">
                                            <img src="@image.Url" class="card-img-top" style="border-radius: 7px; position: absolute; top: 0; bottom: 0; left: 0; right: 0; margin: auto;" alt="...">
                                        </div>
                                        <div class="card-body text-center p-0">
                                            <h5 class="card-title mb-0 pb-0 pt-2" style="font-size:12px;">

                                                @if (image.Name.Length > 12)
                                                {
                                                    @image.Name.Substring(0, 12)<span>...</span>
                                                }
                                                else
                                                {
                                                    @image.Name
                                                }

                                            </h5>
                                            <p class="card-text" style="font-size:11px;">@image.Width * @image.Height</p>
                                        </div>
                                    </div>
                                </a>

                            }
                        }

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" @onclick="() => OnSelectionCancel(false)" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    @*<button type="submit" @onclick="OnSelectionChange" class="btn btn-primary">Done</button>*@
                </div>
            </div>

            @*</EditForm>*@
        </div>
    </div>
}