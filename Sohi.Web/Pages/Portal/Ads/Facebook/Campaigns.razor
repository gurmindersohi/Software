
@using Sohi.Web.Pages.Portal.Ads.Facebook.FacebookComponents;
@using Sohi.Models;

@layout Manage

@page "/Portal/Ads/Facebook/{AccountId}/Create"
@page "/Portal/Ads/Facebook/{AccountId}/Create/Campaigns"


<NewCampaign AccountId="@AccountId"></NewCampaign>


<style>
    .valid.modified:not([type=checkbox]) {
        outline: none;
    }

    .invalid {
        outline: auto red;
    }
</style>


@code{


    [CascadingParameter(Name = "AdsProfile")]
    public Profile Profile { get; set; }

    [Parameter]
    public string AccountId { get; set; }

}