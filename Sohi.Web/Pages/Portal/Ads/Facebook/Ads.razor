
@using Sohi.Web.Pages.Portal.Ads.Facebook.FacebookComponents;

@using Sohi.Models;

@layout Manage

@page "/Portal/Ads/Facebook/{AccountId}/Create/Ads"
@page "/Portal/Ads/Facebook/{AccountId}/Create/Ads/{AdsetId}"


<NewAd AccountId="@AccountId" CampaignId="@CampaignId" AdsetId="@AdsetId"></NewAd>

@code {

    [CascadingParameter(Name = "AdsProfile")]
    public Profile Profile { get; set; }

    [Parameter]
    public string AccountId { get; set; }

    [Parameter]
    public string AdsetId { get; set; }

    [Parameter]
    public string CampaignId { get; set; }
}

<style>
    .valid.modified:not([type=checkbox]) {
        outline: none;
    }

    .invalid {
        outline: auto red;
    }
</style>