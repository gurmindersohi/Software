
@using Sohi.Web.Pages.Portal.Ads.Facebook.FacebookComponents;

@using Sohi.Models;

@layout Manage

@page "/Portal/Ads/Facebook/{AccountId}/Create/Adsets"
@page "/Portal/Ads/Facebook/{AccountId}/Create/Adsets/{CampaignId}"


<NewAdSet AccountId="@AccountId" CampaignId="@CampaignId"></NewAdSet>

@code {

    [CascadingParameter(Name = "AdsProfile")]
    public Profile Profile { get; set; }


    [Parameter]
    public string AccountId { get; set; }


    [Parameter]
    public string CampaignId { get; set; }
}
