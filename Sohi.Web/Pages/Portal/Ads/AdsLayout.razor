


@page "/Portal/Ads"

@inherits AdsLayoutBase

@layout MainLayout

<div class="page">
    <div class="sidebar">

        <AdsMenu FacebookProfile="FacebookProfile" OnPageSelection="PageSelectionChanged" flag="flag" />

    </div>

    <div class="main">


        <CascadingValue Value="Profile" Name="AdsProfile">
