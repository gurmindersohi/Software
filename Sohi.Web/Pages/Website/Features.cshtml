@page
@model Sohi.Web.Pages.Website.FeaturesModel
@{
    ViewBag.Title = "DC - Features";
}

<div class="container-fluid p-0 m-0">

    <header id="home">

        <div class="p-5 bg-light" style="padding-top:200px!important;">
            <div class="container">
                <h2 class="mb-3">Build your website with us</h2>
                <h6 class="mb-3">Expertise in building website for organizations.</h6>
                <a class="btn btn-primary" href="#contact" role="button">Get Started</a>
            </div>
        </div>
    </header>
    <div class="container pt-4 pe-5 pb-5 ps-5" id="features">

        <section class="team-section text-center my-5">
            <h2 class="h1-responsive font-weight-bold my-5">Features</h2>
            <div class="card-group">
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Websites</h5>
                        <p class="card-text">Build your website .</p>
                        @*<p class="card-text"><small class="text-muted">Last updated 3 mins ago</small></p>*@
                    </div>
                </div>
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">.Net/.Net Core Project</h5>
                        <p class="card-text">Build your .Net/.Net Core Project with us using Mvc or three tier Architecture.</p>
                    </div>
                </div>
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Html/Css Project</h5>
                        <p class="card-text">Build your Html/Css Project with us.</p>
                    </div>
                </div>
            </div>
            <div class="card-group">
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Javascript Project</h5>
                        <p class="card-text">Build your Javascript Project with us.</p>
                    </div>
                </div>
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">AngularJs Project</h5>
                        <p class="card-text">Build your AngularJs Project with us.</p>
                    </div>
                </div>
                <div class="card">
                    <img src="~/Images/code.jpg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">NodeJs Project</h5>
                        <p class="card-text">Build your NodeJs Project with us.</p>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Footer -->
    <footer class="bg-light text-lg-start">
        <div class="container p-4">
            <div class="row">

                <div class="col-lg-6 col-md-6 mb-4 mb-md-0">
                    <h2>DC</h2>
                </div>
                <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase">About us</h5>

                    <ul class="list-unstyled mb-0">
                        <li>
                            <a href="#!" class="text-dark">About us</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">Contact</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">Company</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">Jobs</a>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase mb-0">Social</h5>

                    <ul class="list-unstyled">
                        <li>
                            <a href="#!" class="text-dark">Facebook</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">Instagram</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">Twitter</a>
                        </li>
                        <li>
                            <a href="#!" class="text-dark">LinkedIn</a>
                        </li>
                    </ul>
                </div>

            </div>
        </div>

    </footer>
</div>

