@page
@model Sohi.Web.Pages.Website.ContactModel
@{
    ViewBag.Title = "DC - Contact";
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] </title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        .font-weight-bold {
            font-weight: 600 !important;
            font-family: inherit;
        }
    </style>
</head>
<body>

    <div class="container-fluid p-0 m-0">

        <header id="home">
            
            <div class="p-5 bg-light" style="padding-top:200px!important;">
                <div class="container">
                    <h2 class="mb-3">Build your website with us</h2>
                    <h6 class="mb-3">Expertise in building website for organizations.</h6>
                    <a class="btn btn-primary" href="#contact" role="button">Get Started</a>
                </div>
            </div>
        </header>


        <div class="bg-white pt-2 pe-5 pb-5 ps-5" id="contact">
            <div class="container">

                <h2 class="h1-responsive text-center font-weight-bold my-5">Contact us</h2>
                <div class="row">
                    <div class="col-md-3">
                    </div>
                    <div class="col-md-6">
                        <form>
                            <div class="mb-3">
                                <label for="Name" class="form-label">Name</label>
                                <input type="text" class="form-control" id="Name" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <label for="Email" class="form-label">Email address</label>
                                <input type="email" class="form-control" id="Email" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <label for="Description" class="form-label">Description</label>
                                <textarea type="text" cols="6" class="form-control" id="Description"></textarea>
                            </div>
                            <div class="mb-3">
                                <button type="submit" class="btn btn-primary" style="width:100%">Submit</button>
                            </div>
                        </form>
                    </div>
                    <div class="col-md-3">
                    </div>
                </div>
            </div>
        </div>

     
        <!-- Footer -->
        <footer class="bg-light text-lg-start">
            <div class="container p-4">
                <div class="row">

                    <div class="col-lg-6 col-md-6 mb-4 mb-md-0">
                        <h2>DC</h2>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                        <h5 class="text-uppercase">About us</h5>

                        <ul class="list-unstyled mb-0">
                            <li>
                                <a href="#!" class="text-dark">About us</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">Contact</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">Company</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">Jobs</a>
                            </li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                        <h5 class="text-uppercase mb-0">Social</h5>

                        <ul class="list-unstyled">
                            <li>
                                <a href="#!" class="text-dark">Facebook</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">Instagram</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">Twitter</a>
                            </li>
                            <li>
                                <a href="#!" class="text-dark">LinkedIn</a>
                            </li>
                        </ul>
                    </div>

                    
                </div>
            </div>
        </footer>
    </div>


</body>



</html>