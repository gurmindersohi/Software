@page
@model Sohi.Web.Pages.Website.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container">
    <div class="row pt-5 pb-4 justify-content-center h-75">

        @if (Model.IsPlanSelected)
        {

            <div class="col-md-6 pt-2 pb-3 px-4" style="">

                <div class="px-5">
                    <div class="row">
                        <div class="col">
                            <div class="">

                                <a href="/Website/Pricing" class="btn btn-white btn-lg px-0" style=" justify-content: center;  font-size: 14px; font-weight: 500;"><svg class="InlineSVG Icon Header-backArrow mr2 Icon--sm" focusable="false" width="12" height="12" viewBox="0 0 16 16"><path d="M3.417 7H15a1 1 0 0 1 0 2H3.417l4.591 4.591a1 1 0 0 1-1.415 1.416l-6.3-6.3a1 1 0 0 1 0-1.414l6.3-6.3A1 1 0 0 1 8.008 2.41z" fill-rule="evenodd"></path></svg>&nbsp;Back to plans</a>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col">
                            <div class="">
                                <label style="font-weight:500; font-size: 16px; color: rgba(26,26,26,.6); ">Subscribe to DC Premium</label>

                            </div>
                        </div>
                    </div>


                    <div class="row" style="line-height: 1;">
                        <div class="col">
                            <div class="form-group">

                                <h4 class="my-0 fw-normal" style="font-size: 36px; color:#14456b">$@Model.Plans.Price<span style="font-size: 1.3rem;">/mo</span></h4>


                            </div>
                        </div>
                    </div>
                    <div class="row">

                        <div class="">
                            <div style="height:42px; width:42px;">
                                <img src="https://stripe-camo.global.ssl.fastly.net/3faeb3c888d8c7e7d0b7390c01783d3909948e89cfe474d680a99e7b60fd3bcd/68747470733a2f2f66696c65732e7374726970652e636f6d2f6c696e6b732f666c5f746573745f634c744c316b506c6b6e6d6d39307273634b4f3834593962" alt="" style="max-width:100%; max-height:100%;">
                            </div>
                        </div>

                        <div class="col">

                            <div class="row">
                                <div class="col">
                                    <div class="py-2">
                                        <div class="col px-0">
                                            <label class="mb-0 CustomFont2">DC Premium</label>
                                        </div>

                                        <div class="col px-0" style=" line-height: 0.5;">
                                            <label class="mb-0" style=" font-size:12px; font-weight:400; color:rgba(26,26,26,.5);">Billed Monthly</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="py-2 text-right">
                                        <label class="mb-0 CustomFont2 Bold">$@Model.Plans.Price</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row" style="border-bottom: 1px solid rgba(26,26,26,.1);">
                                <div class="col">
                                    <div class="py-2">
                                        <label class="mb-0 CustomFont2">Subtotal</label>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="py-2 text-right">
                                        <label class="mb-0 CustomFont2 Bold">$@Model.Plans.Price</label>
                                    </div>
                                </div>
                            </div>

                            <div class="row" style="border-bottom: 1px solid rgba(26,26,26,.1);">
                                <div class="col">
                                    <div class="py-2">
                                        <label class="mb-0 CustomFont2">Sales tax (13%)</label>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="py-2 text-right">
                                        <label class="mb-0 CustomFont2 Bold">$@Model.Plans.Tax</label>
                                    </div>
                                </div>
                            </div>
                            <div class="row">

                                <div class="col">
                                    <div class="py-2">
                                        <label class="mb-0 CustomFont" style="font-size: 18px;">Total due today</label>
                                    </div>
                                </div>


                                <div class="col">
                                    <div class="py-2 text-right">
                                        <label class="mb-0 CustomFont" style="font-size: 18px;">$@Model.Plans.Total</label>
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            </div>

        }


        <div class="col-md-6 pt-2 pb-3" style=" border-left:1px solid rgba(26,26,26,.1); ">
            @*<form asp-route-returnUrl="@Model.ReturnUrl" method="post" class="col-md-12">
                    <h3 class="title text-center" style="font-size:30px;">Register</h3>
                    <hr />
                    <div class="row">
                        <div class="col">
                            <div class="form-group">
                                <label asp-for="Input.FirstName" class="mb-0 CustomFont"></label>
                                <input asp-for="Input.FirstName" class="form-control CustomInput" placeholder="Steve" />
                                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group">
                                <label asp-for="Input.LastName" class="mb-0 CustomFont"></label>
                                <input asp-for="Input.LastName" class="form-control CustomInput" placeholder="Jobs" />
                                <span asp-validation-for="Input.LastName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>


                    <div class="form-group">
                        <label asp-for="Input.PhoneNumber" class="mb-0 CustomFont"></label>
                        <input asp-for="Input.PhoneNumber" class="form-control CustomInput" placeholder="1(888) 999-0123" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Email" class="mb-0 CustomFont"></label>
                        <input asp-for="Input.Email" class="form-control CustomInput" placeholder="steve.jobs@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Password" class="mb-0 CustomFont"></label>
                        <input asp-for="Input.Password" class="form-control CustomInput" placeholder="*********" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword" class="mb-0 CustomFont"></label>
                        <input asp-for="Input.ConfirmPassword" class="form-control CustomInput" placeholder="*********" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>



                    <div class="form-group text-right">
                        <button type="submit" class="btn btn-primary btn-block">Register</button>
                    </div>
                    <div class="form-group">
                        <div class="row">
                            <div class="col px-5">
                                <label class="mb-0 text-center">By signing up, you agree to DC's Terms of Use, Privacy Policy and Cookie Policy.</label>

                            </div>
                        </div>
                    </div>
                </form>*@

            @if (!Model.IsLoggedIn)
            {

                <section class="px-5">
                    <form id="account" method="post" class="col-md-12">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group">
                            <label asp-for="loginInputModel.Email"></label>
                            <input asp-for="loginInputModel.Email" class="form-control" />
                            <span asp-validation-for="loginInputModel.Email" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="loginInputModel.Password"></label>
                            <input asp-for="loginInputModel.Password" class="form-control" />
                            <span asp-validation-for="loginInputModel.Password" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <div class="checkbox">
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">Log in</button>
                            &nbsp;&nbsp; <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                        </div>

                    </form>
                </section>
            }
            else
            {
                <section class="px-3">
                    <form asp-route-returnUrl="@Model.ReturnUrl" method="post" class="col-md-12">
                        @*<div class="row">
                                <div class="col">
                                    <div class="form-group">
                                        <label asp-for="Input.FirstName" class="mb-0 CustomFont"></label>
                                        <input asp-for="Input.FirstName" class="form-control CustomInput" placeholder="Steve" />
                                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="form-group">
                                        <label asp-for="Input.LastName" class="mb-0 CustomFont"></label>
                                        <input asp-for="Input.LastName" class="form-control CustomInput" placeholder="Jobs" />
                                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>*@


                        @*<div class="form-group">
                                <label asp-for="Input.PhoneNumber" class="mb-0 CustomFont"></label>
                                <input asp-for="Input.PhoneNumber" class="form-control CustomInput" placeholder="1(888) 999-0123" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>*@

                        <div class="form-group">
                            <label asp-for="checkoutInputModel.Email" class="mb-0 CustomFont"></label>
                            <input asp-for="checkoutInputModel.Email" class="form-control Checkout-Input" />
                            @*<span asp-validation-for="checkoutInputModel.Email" class="text-danger"></span>*@
                        </div>

                        <div class="form-group">
                            <label asp-for="checkoutInputModel.CardNumber" class="mb-0 CustomFont"></label>
                            <input asp-for="checkoutInputModel.CardNumber" class="form-control Checkout-Input" style="border-bottom-left-radius:unset!important;  border-bottom-right-radius:unset!important;" placeholder="1234 1234 1234 1234" />
                            <div class="row">
                                <div class="col pr-0" style="border-top: 0;">
                                    <input asp-for="checkoutInputModel.CardExpiry" class="form-control Checkout-Input" style="border-top:none; border-bottom-right-radius:unset!important; border-top-left-radius:unset!important; border-top-right-radius:unset!important;" placeholder="MM / YY" />
                                </div>
                                <div class="col pl-0">
                                    <input asp-for="checkoutInputModel.CardCVD" class="form-control Checkout-Input" style="border-top:none; border-left:none; border-bottom-left-radius:unset!important; border-top-left-radius:unset!important; border-top-right-radius:unset!important;" placeholder="CVC" />
                                </div>
                            </div>

                            @*<span asp-validation-for="checkoutInputModel.CardNumber" class="text-danger"></span>*@
                            @*<span asp-validation-for="checkoutInputModel.CardExpiry" class="text-danger"></span>*@
                            @*<span asp-validation-for="checkoutInputModel.CardCVD" class="text-danger"></span>*@
                        </div>

                        <div class="form-group">
                            <label asp-for="checkoutInputModel.NOC" class="mb-0 CustomFont"></label>
                            <input asp-for="checkoutInputModel.NOC" class="form-control Checkout-Input" />
                            @*<span asp-validation-for="checkoutInputModel.NOC" class="text-danger"></span>*@
                        </div>

                        <div class="form-group">
                            <label asp-for="checkoutInputModel.Country" class="mb-0 CustomFont"></label>
                            <input asp-for="checkoutInputModel.Country" class="form-control Checkout-Input" style="border-bottom:none; border-bottom-left-radius:unset!important;  border-bottom-right-radius:unset!important;"  placeholder="Country" />
                            <input asp-for="checkoutInputModel.ZIP" class="form-control Checkout-Input" style="border-top-left-radius:unset!important;  border-top-right-radius:unset!important;" placeholder="ZIP" />

                            @*<span asp-validation-for="checkoutInputModel.Country" class="text-danger"></span>*@
                        </div>



                        <div class="form-group text-right">
                            <button type="button" class="btn btn-primary btn-block">Subscribe</button>
                        </div>
                        <div class="form-group">
                            <div class="row">
                                <div class="col px-5">
                                    <label class="mb-0 text-center" style="font-size: 13px; color: rgba(26,26,26,.6);">By confirming your subscription, you allow DC to charge your card for this payment and future payments in accordance with their terms.</label>

                                </div>
                            </div>
                        </div>
                    </form>

                </section>
            }
        </div>

    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

