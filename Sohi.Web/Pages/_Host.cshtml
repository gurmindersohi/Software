@page "/"
@namespace Sohi.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DC</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="Sohi.Web.styles.css" rel="stylesheet" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>

    <div id="fb-root"></div>
    <script src="https://connect.facebook.net/en_US/sdk.js" nonce="Jvlg9Dza"></script>
    <script nonce="Jvlg9Dza">FB.init({
            appId: 1133254180447928,
            status: true,
            xfbml: true,
            version: 'v10.0'
        });
        FB.AppEvents.logPageView();</script>

    <script src="js/FacebookJS.js"></script>

</body>
</html>
