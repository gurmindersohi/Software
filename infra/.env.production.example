# ===========================================================================
# Consolidated production env manifest (task 9.2). Copy to infra/.env.production
# and fill in. EVERY secret here must be freshly ROTATED — never reuse the
# values that leaked from the old appsettings.json git history (task 0.6).
# ===========================================================================

# --- Postgres ---
POSTGRES_USER=sohi
POSTGRES_PASSWORD=__change_me__
POSTGRES_DB=sohi

# --- Backend (api + worker) ---
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=__long_random_string__
DATABASE_URL=postgresql+psycopg://sohi:__change_me__@db:5432/sohi
REDIS_URL=redis://redis:6379/0

# Token encryption at rest — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=__fernet_key__

# Auth / CORS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_ORIGIN=https://app.yourdomain.com

# Object storage (S3 / MinIO)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://s3.yourprovider.com
S3_BUCKET=sohi-media
S3_ACCESS_KEY=__rotated__
S3_SECRET_KEY=__rotated__

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@yourdomain.com
RESEND_API_KEY=__rotated__

# --- Integrations (ROTATED) ---
FACEBOOK_APP_ID=__rotated__
FACEBOOK_APP_SECRET=__rotated__
FACEBOOK_GRAPH_VERSION=v19.0
FACEBOOK_REDIRECT_URL=https://api.yourdomain.com/api/v1/integrations/facebook/callback

STRIPE_SECRET_KEY=__rotated__
STRIPE_WEBHOOK_SECRET=__rotated__
# Publishable key (not secret) — used by the frontend Stripe Elements form
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# --- Frontend (build/runtime) ---
BACKEND_URL=http://api:8000
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_UNLIMITED=price_xxx

# --- ETL (one-time data migration) ---
# SQL Server source, e.g. mssql+pyodbc://user:pass@host/Sohi?driver=ODBC+Driver+18+for+SQL+Server
SOURCE_DATABASE_URL=
